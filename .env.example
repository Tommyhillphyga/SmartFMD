PROJECT_NAME=Smart Fuel Dispenser Monitoring Dashboard
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost
JWT_SECRET_KEY=change-me-access
JWT_REFRESH_SECRET_KEY=change-me-refresh
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+asyncpg://smartfmd:smartfmd@postgres:5432/smartfmd
REDIS_URL=redis://redis:6379/0
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=fuel
MQTT_ENABLED=true
APP_AUTO_CREATE_SCHEMA=false
PROMETHEUS_ENABLED=true
EMAIL_FROM=noreply@example.com
SMTP_HOST=mailhog
SMTP_PORT=1025
SMS_WEBHOOK_URL=https://example.com/sms
WHATSAPP_WEBHOOK_URL=https://example.com/whatsapp
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_WS_BASE_URL=ws://localhost/api
NEXT_PUBLIC_APP_NAME=SMART FUEL DISPENSER MONITORING DASHBOARD
