PROJECT_NAME=Smart Fuel Dispenser Monitoring Dashboard
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
JWT_SECRET_KEY=change-me-access
JWT_REFRESH_SECRET_KEY=change-me-refresh
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+asyncpg://smartfmd:smartfmd@localhost:5432/smartfmd
REDIS_URL=redis://localhost:6379/0
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=fuel
MQTT_ENABLED=true
APP_AUTO_CREATE_SCHEMA=false
PROMETHEUS_ENABLED=true
EMAIL_FROM=noreply@example.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMS_WEBHOOK_URL=https://example.com/sms
WHATSAPP_WEBHOOK_URL=https://example.com/whatsapp
